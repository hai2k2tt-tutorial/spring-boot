<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="src/main/resources/db/changelog/db.changelog-master.xml"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="2-soft-delete-products" author="codex">
        <addColumn tableName="t_product">
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>

        <createIndex tableName="t_product" indexName="idx_product_deleted_at">
            <column name="deleted_at"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="t_product" indexName="idx_product_deleted_at"/>
            <dropColumn tableName="t_product" columnName="deleted_at"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
