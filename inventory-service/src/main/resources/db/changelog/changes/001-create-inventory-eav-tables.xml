<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="src/main/resources/db/changelog/db.changelog-master.xml"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="1-create-inventory-eav-tables" author="codex">
        <createTable tableName="t_attribute">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="input_type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="t_attribute_value">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="attribute_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT"/>
        </createTable>

        <createTable tableName="t_sku">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="sku_code" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="price_override" type="NUMERIC(19,2)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="t_sku_attribute_value">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sku_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_value_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="t_inventory">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sku_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="t_attribute_value" baseColumnNames="attribute_id"
                                 constraintName="fk_attribute_value_attribute"
                                 referencedTableName="t_attribute" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="t_sku_attribute_value" baseColumnNames="sku_id"
                                 constraintName="fk_sku_attribute_value_sku"
                                 referencedTableName="t_sku" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="t_sku_attribute_value" baseColumnNames="attribute_value_id"
                                 constraintName="fk_sku_attribute_value_attribute_value"
                                 referencedTableName="t_attribute_value" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="t_inventory" baseColumnNames="sku_id"
                                 constraintName="fk_inventory_sku"
                                 referencedTableName="t_sku" referencedColumnNames="id"/>

        <createIndex tableName="t_attribute" indexName="idx_attribute_product_id">
            <column name="product_id"/>
        </createIndex>
        <createIndex tableName="t_attribute_value" indexName="idx_attribute_value_attribute_id">
            <column name="attribute_id"/>
        </createIndex>
        <createIndex tableName="t_sku" indexName="idx_sku_product_id">
            <column name="product_id"/>
        </createIndex>
        <createIndex tableName="t_sku_attribute_value" indexName="idx_sku_attribute_value_sku_id">
            <column name="sku_id"/>
        </createIndex>
        <createIndex tableName="t_sku_attribute_value" indexName="idx_sku_attribute_value_attribute_value_id">
            <column name="attribute_value_id"/>
        </createIndex>

        <addUniqueConstraint tableName="t_attribute" columnNames="product_id,code"
                             constraintName="uk_attribute_product_code"/>
        <addUniqueConstraint tableName="t_attribute_value" columnNames="attribute_id,value"
                             constraintName="uk_attribute_value_attribute_value"/>
        <addUniqueConstraint tableName="t_sku_attribute_value" columnNames="sku_id,attribute_value_id"
                             constraintName="uk_sku_attribute_value_pair"/>

        <sql>
            ALTER TABLE t_attribute
            ADD CONSTRAINT chk_attribute_input_type
            CHECK (input_type IN ('SELECT', 'TEXT'));
        </sql>

        <rollback>
            <dropTable tableName="t_inventory"/>
            <dropTable tableName="t_sku_attribute_value"/>
            <dropTable tableName="t_sku"/>
            <dropTable tableName="t_attribute_value"/>
            <dropTable tableName="t_attribute"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
