<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="src/main/resources/db/changelog/db.changelog-master.xml"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="2-drop-customer-auth-password-hash" author="codex">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="t_customer_auth" columnName="password_hash"/>
        </preConditions>
        <dropColumn tableName="t_customer_auth" columnName="password_hash"/>
        <rollback>
            <addColumn tableName="t_customer_auth">
                <column name="password_hash" type="VARCHAR(255)" defaultValue="external-auth">
                    <constraints nullable="false"/>
                </column>
            </addColumn>
        </rollback>
    </changeSet>
</databaseChangeLog>
