{
  "realm": "ecommerce-customer",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "customer",
        "description": "Customer frontend users",
        "composite": false,
        "clientRole": false,
        "attributes": {}
      }
    ]
  },
  "clients": [
    {
      "clientId": "customer-fe-client",
      "name": "Customer Frontend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:3004",
        "http://localhost:3004/api/auth/callback/keycloak",
        "http://localhost:3004/api/customer-fe-next/auth/callback/keycloak",
        "http://customer-fe-next.local:8080",
        "http://customer-fe-next.local:8080/*",
        "http://customer-fe-next.local:8080/api/auth/callback/keycloak",
        "http://customer-fe-next.local:8080/api/customer-fe-next/auth/callback/keycloak",
        "http://customer-fe-next.haint.fyi",
        "http://customer-fe-next.haint.fyi/*",
        "http://customer-fe-next.haint.fyi/api/auth/callback/keycloak",
        "http://customer-fe-next.haint.fyi/api/customer-fe-next/auth/callback/keycloak",
        "http://localhost:3006",
        "http://localhost:3006/api/customer-wallet-fe/auth/callback/keycloak",
        "http://customer-wallet-fe.local:8080",
        "http://customer-wallet-fe.local:8080/*",
        "http://customer-wallet-fe.local:8080/api/customer-wallet-fe/auth/callback/keycloak",
        "http://customer-wallet-fe.haint.fyi",
        "http://customer-wallet-fe.haint.fyi/*",
        "http://customer-wallet-fe.haint.fyi/api/customer-wallet-fe/auth/callback/keycloak",
        "http://localhost:3005",
        "http://localhost:3005/api/customer-wallet-fe/auth/callback/keycloak"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "oidc.ciba.grant.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false"
      },
      "protocolMappers": [
        {
          "name": "user id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "id",
            "claim.name": "user_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ]
}
