{
  "realm": "ecommerce-admin",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administration frontend users",
        "composite": false,
        "clientRole": false,
        "attributes": {}
      }
    ]
  },
  "clients": [
    {
      "clientId": "admin-fe-client",
      "name": "Admin Frontend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:3002",
        "http://localhost:3002/api/auth/callback/keycloak",
        "http://admin-fe.local:8080",
        "http://admin-fe.local:8080/*",
        "http://admin-fe.local:8080/api/auth/callback/keycloak",
        "http://admin-fe.haint.fyi",
        "http://admin-fe.haint.fyi/*",
        "http://admin-fe.haint.fyi/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "oidc.ciba.grant.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false"
      },
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ]
}
