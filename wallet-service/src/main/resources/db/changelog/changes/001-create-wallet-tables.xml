<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="src/main/resources/db/changelog/db.changelog-master.xml"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="1-create-wallet-tables" author="codex">
        <createTable tableName="t_wallet">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_type" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="t_wallet_transaction">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="wallet_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="owner_type" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="balance_after" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="external_ref" type="VARCHAR(128)"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="t_wallet_transaction" baseColumnNames="wallet_id"
                                 constraintName="fk_wallet_transaction_wallet"
                                 referencedTableName="t_wallet" referencedColumnNames="id"/>
        <createIndex tableName="t_wallet" indexName="idx_wallet_owner" unique="true">
            <column name="owner_type"/>
            <column name="owner_id"/>
        </createIndex>
        <createIndex tableName="t_wallet_transaction" indexName="idx_wallet_transaction_owner_created">
            <column name="owner_type"/>
            <column name="owner_id"/>
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="t_wallet_transaction" indexName="idx_wallet_transaction_owner_type_ref" unique="true">
            <column name="owner_type"/>
            <column name="owner_id"/>
            <column name="type"/>
            <column name="external_ref"/>
        </createIndex>
        <sql>
            ALTER TABLE t_wallet ADD CONSTRAINT chk_wallet_owner_type CHECK (owner_type IN ('CUSTOMER', 'SHOP'));
        </sql>
        <sql>
            ALTER TABLE t_wallet_transaction ADD CONSTRAINT chk_wallet_transaction_owner_type CHECK (owner_type IN ('CUSTOMER', 'SHOP'));
        </sql>
        <sql>
            ALTER TABLE t_wallet_transaction ADD CONSTRAINT chk_wallet_transaction_type CHECK (type IN ('CREDIT', 'DEBIT'));
        </sql>
        <rollback>
            <dropTable tableName="t_wallet_transaction"/>
            <dropTable tableName="t_wallet"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
