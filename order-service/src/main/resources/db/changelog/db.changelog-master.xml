<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="1-create-order-tables" author="codex">
        <createTable tableName="t_order">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_number" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="customer_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="t_order_item">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="sku_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="shop_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="NUMERIC(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="t_order_item" baseColumnNames="order_id"
                                 constraintName="fk_order_item_order"
                                 referencedTableName="t_order" referencedColumnNames="id"/>

        <createIndex tableName="t_order" indexName="idx_order_customer_id">
            <column name="customer_id"/>
        </createIndex>
        <createIndex tableName="t_order_item" indexName="idx_order_item_order_id">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="t_order_item" indexName="idx_order_item_shop_id">
            <column name="shop_id"/>
        </createIndex>

        <sql>
            ALTER TABLE t_order
            ADD CONSTRAINT chk_order_status
            CHECK (status IN ('PENDING', 'PAID', 'CANCELED'));
        </sql>

        <rollback>
            <dropTable tableName="t_order_item"/>
            <dropTable tableName="t_order"/>
        </rollback>
    </changeSet>

    <changeSet id="2-add-checkout-idempotency-and-pending-payment-status" author="codex">
        <addColumn tableName="t_order">
            <column name="idempotency_key" type="VARCHAR(128)"/>
        </addColumn>

        <createIndex tableName="t_order" indexName="idx_order_customer_idempotency_key" unique="true">
            <column name="customer_id"/>
            <column name="idempotency_key"/>
        </createIndex>

        <sql>
            ALTER TABLE t_order DROP CONSTRAINT chk_order_status;
        </sql>

        <sql>
            ALTER TABLE t_order
            ADD CONSTRAINT chk_order_status
            CHECK (status IN ('PENDING_PAYMENT', 'PENDING', 'PAID', 'CANCELED'));
        </sql>

        <rollback>
            <sql>
                ALTER TABLE t_order DROP CONSTRAINT chk_order_status;
            </sql>
            <sql>
                ALTER TABLE t_order
                ADD CONSTRAINT chk_order_status
                CHECK (status IN ('PENDING', 'PAID', 'CANCELED'));
            </sql>
            <dropIndex tableName="t_order" indexName="idx_order_customer_idempotency_key"/>
            <dropColumn tableName="t_order" columnName="idempotency_key"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
